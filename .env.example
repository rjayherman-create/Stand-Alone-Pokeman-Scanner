# ============================================================
# Retail Flip Scanner — Environment Variables
# Copy this file to .env and fill in the values.
# On Railway, set these in the service's Variables tab.
# ============================================================

# ----- Required -----

# PostgreSQL connection string — format: ******HOST:5432/DB_NAME
# Railway Postgres plugin sets this automatically via the ${{Postgres.DATABASE_URL}} variable reference.
DATABASE_URL=<your-postgres-connection-string>

# OpenAI API key and base URL
# For the standard OpenAI API use https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Port the Express server listens on (Railway sets this automatically)
PORT=8080

# ----- Optional -----

# Base path for frontend deployments under a subpath
# BASE_PATH=/

# Log level for pino (default: "info")
# LOG_LEVEL=info

# eBay Browse API credentials (only needed for eBay price lookups)
# EBAY_CLIENT_ID=
# EBAY_CLIENT_SECRET=
# EBAY_MARKETPLACE_ID=EBAY_US

# Amazon/Keepa API integration (only needed for Amazon data source lookups)
# AMAZON_API_ENABLED=false
# KEEPA_API_KEY=
