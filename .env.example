# ============================================================
# PokéVault / Retail Flip Scanner — Environment Variables
# Copy this file to .env and fill in the values.
# On Railway, set these in the web service's Variables tab.
# ============================================================

# ----- Required -----

# Railway Postgres reference example: ${{Postgres.DATABASE_URL}}
DATABASE_URL=<your-postgres-connection-string>

AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# Railway sets PORT automatically in production.
PORT=8080

# ----- Pokémon current-market sources -----

# eBay Browse API: current active listings. This is not completed-sale history.
# Create production keys in the eBay Developers Program.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_US

# TCGplayer official product pricing. Each inventory record also needs its
# TCGplayer product ID stored in analysis_json.tcgplayerId.
TCGPLAYER_PUBLIC_KEY=
TCGPLAYER_PRIVATE_KEY=

# PriceCharting official API. Each inventory record also needs its
# PriceCharting product ID stored in analysis_json.priceChartingId.
PRICECHARTING_TOKEN=

# Mercari does not provide a supported public market-pricing API.
# Mercari, Facebook Marketplace, local card shops, and other unsupported
# marketplaces must be recorded as verified manual comparable sales.

# ----- Optional scanner sources -----
AMAZON_API_ENABLED=false
KEEPA_API_KEY=
AMAZON_CREATORS_API_KEY=
AMAZON_PARTNER_TAG=

COMP_LOOKUP_TIMEOUT_SECONDS=12
MAX_EBAY_RESULTS=20
MIN_MATCH_CONFIDENCE=70
FACEBOOK_LOCAL_DISCOUNT_LOW=0.70
FACEBOOK_LOCAL_DISCOUNT_HIGH=0.85
AMAZON_REFERENCE_ONLY=true
LOG_LEVEL=info
